{
  "name": "@stale-styles/css-modules",
  "version": "1.0.0-beta.4",
  "description": "Importable CSS Modules class checker application API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stalecheck/stale-styles.git",
    "directory": "packages/css-modules-app"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run --root ../.. --project css-modules-app",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lightningcss": "catalog:default",
    "oxc-parser": "catalog:default",
    "oxc-resolver": "catalog:default"
  },
  "devDependencies": {
    "@stale-styles/core": "workspace:*"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
