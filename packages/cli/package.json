{
  "name": "css-modules-class-checker-cli",
  "version": "1.0.0",
  "description": "Executable CLI for css-modules-class-checker.",
  "license": "MIT",
  "bin": {
    "css-modules-class-checker-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup --config ./tsup.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run --root ../.. packages/cli/tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "css-modules-class-checker": "*",
    "lightningcss": "^1.32.0",
    "oxc-parser": "^0.133.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
