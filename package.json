{
  "name": "@stale-styles/monorepo",
  "version": "1.0.0-beta.3",
  "private": true,
  "description": "Monorepo for styles that have been stale, checking tools packages.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "workspaces": [
    "packages/core",
    "packages/css-modules-app",
    "packages/cli",
    "packages/eslint-plugin"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "release": "commit-and-tag-version",
    "release:beta": "commit-and-tag-version --prerelease beta",
    "release:dry-run": "commit-and-tag-version --dry-run",
    "test": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.7",
    "commit-and-tag-version": "12.7.3",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "overrides": {
    "lightningcss": "catalog:default",
    "oxc-parser": "catalog:default",
    "oxc-resolver": "catalog:default"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
