{
  "name": "css-modules-class-checker",
  "version": "1.0.0-beta.1",
  "description": "Checks CSS Modules class usages in JavaScript and TypeScript projects.",
  "license": "MIT",
  "bin": {
    "css-modules-class-checker": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "lightningcss": "^1.32.0",
    "oxc-parser": "^0.133.0"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}