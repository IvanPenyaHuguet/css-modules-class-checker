{
  "name": "css-modules-class-checker-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for CSS Modules class checking packages.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/app",
    "packages/cli",
    "packages/eslint-plugin"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "format": "npm run format --workspaces",
    "format:check": "npm run format:check --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "overrides": {
    "lightningcss": "1.32.0",
    "oxc-parser": "0.133.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
