{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "paths": {
      "@stale-styles/core": ["./packages/core/src/index.ts"],
      "@stale-styles/css-modules": ["./packages/css-modules-app/src/index.ts"],
      "@stale-styles/eslint-plugin": ["./packages/eslint-plugin/src/index.ts"],
      "@stale-styles/eslint-plugin/css-modules": [
        "./packages/eslint-plugin/src/css-modules.ts"
      ]
    },
    "ignoreDeprecations": "6.0",
    "types": ["node", "vitest/globals"]
  }
}
