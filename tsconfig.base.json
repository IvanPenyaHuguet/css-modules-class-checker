{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "paths": {
      "css-modules-class-checker-core": ["./packages/core/src/index.ts"],
      "css-modules-class-checker": ["./packages/app/src/index.ts"],
      "eslint-plugin-css-modules-class-checker": ["./packages/eslint-plugin/src/index.ts"]
    },
    "ignoreDeprecations": "6.0",
    "types": ["node", "vitest/globals"]
  }
}
